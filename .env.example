# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_API_KEY=your-search-key-here
AZURE_SEARCH_INDEX_NAME=sprag-index

# Azure Storage
STORAGE_CONNECTION_STRING=your-connection-string-here
BLOB_CONTAINER_NAME=sharepoint-documents

# Cosmos DB
COSMOS_CONNECTION_STRING=your-connection-string-here
COSMOS_DB_DATABASE=ChatDB
COSMOS_DB_CONTAINER=conversations

# Entra ID (Graph API)
GRAPH_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GRAPH_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GRAPH_CLIENT_SECRET=your-secret-here

# Application Insights (optional)
APPLICATIONINSIGHTS_CONNECTION_STRING=your-connection-string-here
